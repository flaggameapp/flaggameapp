{
  "manifest_version": 3,
  "name": "Flag Game",
  "short_name": "Flag Game",
  "version": "1.1.0",
  "description": "Learn and master the flags of the world's 195 countries through multiple game modes, achievements and progressive challenges.",
  "homepage_url": "https://flaggameapp.github.io/flaggameapp/",
  "icons": {
    "16": "assets/images/logo16.png",
    "32": "assets/images/logo32.png",
    "48": "assets/images/logo48.png",
    "128": "assets/images/logo128.png"
  },
  "action": {
    "default_title": "Open Flag Game",
    "default_icon": {
      "16": "assets/images/logo16.png",
      "32": "assets/images/logo32.png",
      "48": "assets/images/logo48.png",
      "128": "assets/images/logo128.png"
    }
  },
  "background": {
    "scripts": [
      "js/background.js"
    ],
    "service_worker": "js/background.js"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "flaggame@flaggame.app",
      "strict_min_version": "121.0",
      "data_collection_permissions": {
        "required": [
          "none"
        ]
      }
    }
  }
}
